{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "LazyTunes default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "sql:allow-select",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/Music/**" },
        { "path": "$AUDIO/**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/Music/**" },
        { "path": "$AUDIO/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$APPDATA/**" },
        { "path": "$HOME/Music/**" },
        { "path": "$AUDIO/**" }
      ]
    },
    "fs:allow-exists",
    "fs:allow-watch",
    "dialog:default",
    "dialog:allow-open",
    "store:default",
    "global-shortcut:default",
    "global-shortcut:allow-register"
  ]
}
